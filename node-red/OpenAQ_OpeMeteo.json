    {
        "id": "89b5a0f2874ea6dd",
        "type": "function",
        "z": "8c37327f240f17af",
        "name": "function 3",
        "func": "if (!msg.payload || !msg.payload.current) {\n    node.error(\"No current weather data from Open-Meteo\");\n    return null;\n}\n\nlet c = msg.payload.current;\n\nlet lat = msg.payload.latitude || 13.8462;\nlet lon = msg.payload.longitude || 100.5690;\n\nlet recorded_at = \"NOW()\";\nif (c.time) {\n    recorded_at = `STR_TO_DATE('${c.time}', '%Y-%m-%dT%H:%i')`;\n}\n\nmsg.topic = `\nINSERT INTO openmeteo_readings\n(source, lat, lon, temperature_2m, relative_humidity_2m, precipitation, weather_code, wind_speed_10m, recorded_at, fetched_at)\nVALUES\n(\n  'openmeteo',\n  ${lat},\n  ${lon},\n  ${c.temperature_2m ?? 0},\n  ${c.relative_humidity_2m ?? 0},\n  ${c.precipitation ?? 0},\n  ${c.weather_code ?? 0},\n  ${c.wind_speed_10m ?? 0},\n  ${recorded_at},\n  NOW()\n);`;\n\nreturn msg;",

    {
        "id": "978d94f8a6344d81",
        "type": "function",
        "z": "8c37327f240f17af",
        "name": "function 2",
        "func": "// OpenAQ API v3 response structure\nif (!msg.payload || !msg.payload.results || msg.payload.results.length === 0) {\n    node.error(\"No results from OpenAQ v3\");\n    return null;\n}\n\nlet r = msg.payload.results[0];\n\n// พิกัดเซ็นเซอร์ของเรา\nlet myLat = 13.8462;\nlet myLon = 100.5690;\n\n// ข้อมูลจาก OpenAQ v3\nlet pm25 = r.value;\nlet lat = r.coordinates ? r.coordinates.latitude : 0;\nlet lon = r.coordinates ? r.coordinates.longitude : 0;\nlet sensorId = r.sensorsId || 0;\nlet locationId = r.locationsId || 0;\n\n// Haversine distance\nfunction toRad(x) { return x * Math.PI / 180; }\nlet R = 6371;\nlet dLat = toRad(lat - myLat);\nlet dLon = toRad(lon - myLon);\nlet a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +\n    Math.cos(toRad(myLat)) * Math.cos(toRad(lat)) *\n    Math.sin(dLon / 2) * Math.sin(dLon / 2);\nlet distance_km = R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n\n// เวลา - v3 format\nlet recorded_at = \"NOW()\";\nif (r.datetime && r.datetime.utc) {\n    let utc = r.datetime.utc.replace('T', ' ').replace('Z', '');\n    recorded_at = `'${utc}'`;\n}\n\nmsg.topic = `\nINSERT INTO official_pm25\n(source, station_name, lat, lon, distance_km, pm25, unit, recorded_at, fetched_at)\nVALUES (\n  'openaq_v3',\n  'location_${locationId}',\n  ${lat},\n  ${lon},\n  ${distance_km.toFixed(2)},\n  ${pm25},\n  'ug/m3',\n  ${recorded_at},\n  NOW()\n);`;\n\nreturn msg;",
